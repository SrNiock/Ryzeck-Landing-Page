---
import '@fontsource/inter/400.css';
import '@fontsource/inter/700.css';
import NavBar from '../components/navbar/NavBar.astro';

interface Props {
  title?: string;
}

const { title = "Ryzeck"} = Astro.props; 
---


<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<NavBar />
		<slot />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
		background-color: black;
	}

	section {
        padding: 100px 0;
        border-bottom: 1px solid #1a1a1a;
        background-color: #050505; 
    }

    .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 2rem; 
    }

    .header-section {
        margin-bottom: 60px; 
        text-align: left;
    }

    .header-section h2 {
        font-size: 2.5rem;
        font-weight: 800;
        letter-spacing: -0.02em;
        line-height: 1.1;
        margin: 0;
        text-transform: uppercase;
    }

    .underline {
        width: 60px;
        height: 4px;
        background-color: white;
        margin-top: 15px;
    }
</style>
