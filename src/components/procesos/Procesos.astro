<style>
  .metodologia {
    background-color: #050505;
    padding: 80px 0 120px 0; 
    font-family: "Inter", sans-serif;
    color: white;
    border-bottom: 1px solid #1a1a1a;
    overflow: hidden;
  }

  .container {
    max-width: 1200px; 
    margin: 0 auto;    
    padding: 0 2rem;
  }

  .header-section,
  .step-card {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s ease-out, transform 0.8s cubic-bezier(0.2, 1, 0.3, 1);
    will-change: transform, opacity;
  }

  .reveal {
    opacity: 1;
    transform: translateY(0);
  }

  .step-card:nth-child(1) { transition-delay: 0.1s; }
  .step-card:nth-child(2) { transition-delay: 0.2s; }
  .step-card:nth-child(3) { transition-delay: 0.3s; }
  .step-card:nth-child(4) { transition-delay: 0.4s; }

  .step-card.reveal:hover {
    transition: transform 0.3s ease-out, border-color 0.3s ease, background-color 0.3s ease;
    transition-delay: 0s !important; 
    
    transform: translateY(-10px) !important;
    border-color: #333;
    background: #0f0f0f;
  }

  .header-section {
    margin-bottom: 60px;
    text-align: left;
  }

  .eyebrow {
    color: #9ca3af;
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.2em;
    display: block;
    margin-bottom: 1rem;
    text-transform: uppercase;
  }

  .header-section h2 {
    font-size: 2.8rem;
    font-weight: 800;
    margin: 0;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .underline {
    width: 60px;
    height: 4px;
    background-color: white;
    margin-top: 15px;
  }

  .steps-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr); 
    gap: 20px;
    margin-top: 60px;
  }

  .step-card {
    position: relative;
    padding: 30px 25px;
    background: #0a0a0a;
    border: 1px solid #1a1a1a;
    border-radius: 20px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .step-number {
    position: absolute;
    top: 20px;
    right: 20px;
    font-size: 4rem;
    font-weight: 900;
    color: rgba(255, 255, 255, 0.03);
    line-height: 1;
    pointer-events: none;
    z-index: 1;
    user-select: none;
  }

  .icon-box {
    width: 50px;
    height: 50px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 25px;
    position: relative;
    z-index: 2;
  }

  .icon-box.blue { background: rgba(59, 130, 246, 0.1); color: #3b82f6; }
  .icon-box.purple { background: rgba(168, 85, 247, 0.1); color: #a855f7; }
  .icon-box.green { background: rgba(16, 185, 129, 0.1); color: #10b981; }
  .icon-box.orange { background: rgba(249, 115, 22, 0.1); color: #f97316; }

  .step-card h3 {
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: 12px;
    position: relative;
    z-index: 2;
  }

  .step-card p {
    color: #888;
    line-height: 1.6;
    font-size: 0.9rem;
    margin: 0;
    position: relative;
    z-index: 2;
  }

  @media (max-width: 1100px) {
    .steps-grid {
      grid-template-columns: repeat(2, 1fr); 
    }
    .header-section h2 { font-size: 2.2rem; }
  }

  @media (max-width: 650px) {
    .steps-grid {
      grid-template-columns: 1fr;
      gap: 5rem;
    }
    .metodologia { padding: 60px 0; }
    .header-section h2 { font-size: 1.8rem; }
    .step-card { padding: 30px 20px; }
  }
</style>

<script>
  const initAnimations = () => {
    const observerOptions = {
      threshold: 0.1, 
      rootMargin: "0px 0px -50px 0px"
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("reveal");
          observer.unobserve(entry.target);
        }
      });
    }, observerOptions);

    const elementsToAnimate = document.querySelectorAll(".header-section, .step-card");
    elementsToAnimate.forEach((el) => observer.observe(el));
  };

  initAnimations();

  document.addEventListener("astro:after-swap", initAnimations);
</script>