<section class="hero">
  <canvas class="particles-canvas" id="particles"></canvas>
  
  <div class="bg-layer aurora-1"></div>
  <div class="dot-grid"></div>

  <div class="container hero-container">
    <div class="badge fade-in-up">
      <span class="dot"></span>
      <p>Impulsando la Transformación Digital</p>
    </div>

    <h1 class="fade-in-up delay-1">
      Construimos el <span class="highlight">Futuro Digital</span> de tu proyecto
    </h1>

    <p class="hero-description fade-in-up delay-2">
      En <strong class="brand">Ryzeck</strong>, transformamos ideas audaces en aplicaciones web y móviles
      de alto impacto. Especialistas en SaaS y desarrollo a medida para
      empresas que no se detienen.
    </p>

    <div class="fade-in-up delay-3">
        <button class="btn-contacto">
            HABLEMOS DE TU IDEA <span>→</span>
        </button>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    background-color: #000;
    overflow: hidden;
    padding: 100px 0;
    min-height: 85vh;
    display: flex;
    align-items: center;
    justify-content: center;
    border-bottom: 1px solid #1a1a1a;
  }

  .particles-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1; 
  }

  .fade-in-up {
    opacity: 0;
    transform: translateY(20px);
    animation: heroFadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .delay-1 { animation-delay: 0.2s; }
  .delay-2 { animation-delay: 0.4s; }
  .delay-3 { animation-delay: 0.6s; }

  @keyframes heroFadeIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .highlight {
    display: inline-block;
    background: linear-gradient(135deg, #10b981 0%, #34d399 50%, #6ee7b7 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    background-size: 200% 200%;
    animation: 
      shimmer 3s ease-in-out infinite,
      heartbeat 2s ease-in-out infinite; 
    will-change: transform;
  }

  @keyframes heartbeat {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.05); }
  }

  @keyframes shimmer {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  .bg-layer {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    filter: blur(80px);
  }

  .aurora-1 {
    width: 700px; height: 700px;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    background: radial-gradient(circle, rgba(16, 185, 129, 0.12) 0%, transparent 70%);
    z-index: 2;
  }

  .dot-grid {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(255, 255, 255, 0.05) 1px, transparent 1px);
    background-size: 32px 32px;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 30%, transparent 100%);
    z-index: 2;
  }

  .hero-container {
    position: relative;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    text-align: center;
    max-width: 1000px;
    padding: 0 20px;
  }

  h1 {
    font-size: clamp(2.5rem, 6vw, 4rem);
    line-height: 1.1;
    color: white;
    margin: 0;
    font-weight: 800;
  }

  .hero-description {
    max-width: 750px;
    color: #9ca3af;
    font-size: 1.1rem;
    line-height: 1.6;
    margin: 0;
  }

  .brand { color: #10b981; font-weight: 800; }

  .badge {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid #222;
    padding: 0.4rem 1.2rem;
    border-radius: 9999px;
  }

  .badge p {
    font-size: 0.75rem;
    font-weight: 700;
    color: #10b981;
    text-transform: uppercase;
    margin: 0;
  }

  .dot {
    width: 6px; height: 6px;
    background-color: #10b981;
    border-radius: 50%;
    box-shadow: 0 0 10px rgba(16, 185, 129, 0.5);
  }

  .btn-contacto {
    background-color: white;
    color: black;
    padding: 1.2rem 2.5rem;
    border-radius: 8px;
    border: none;
    cursor: pointer;
    font-weight: 800;
    text-transform: uppercase;
    transition: all 0.3s ease;
  }

  .btn-contacto:hover {
    transform: scale(1.05);
    box-shadow: 0 0 30px rgba(16, 185, 129, 0.25);
  }
</style>

<script>
  class Particle {
    x!: number;
    y!: number;
    vx!: number;
    vy!: number;
    radius!: number;
    alpha!: number;
    maxAlpha!: number;
    life!: number;
    maxLife!: number;

    constructor(private canvasW: number, private canvasH: number) {
      this.reset(true);
    }

    reset(init = false) {
      this.x = Math.random() * this.canvasW;
      
      if (init || Math.random() > 0.1) { 
        this.y = Math.random() * this.canvasH;
      } else {
        this.y = this.canvasH + 20;
      }
      
      this.radius = Math.random() * 1.3 + 0.4;
      this.vx = (Math.random() - 0.5) * 0.2;
      this.vy = (Math.random() - 0.5) * 0.2 - 0.1;
      
      this.life = 0;
      this.maxLife = Math.random() * 400 + 300;
      this.alpha = 0;
      this.maxAlpha = Math.random() * 0.4 + 0.1;
    }

    update(w: number, h: number) {
      this.x += this.vx;
      this.y += this.vy;
      this.life++;

      const progress = this.life / this.maxLife;
      if (progress < 0.2) this.alpha = (progress / 0.2) * this.maxAlpha;
      else if (progress > 0.7) this.alpha = this.maxAlpha * (1 - (progress - 0.7) / 0.3);
      else this.alpha = this.maxAlpha;

      if (this.y < -50 || this.y > h + 50 || this.life >= this.maxLife) {
        this.reset(true); 
      }
      if (this.x < 0 || this.x > w) this.vx *= -1;
    }

    draw(ctx: CanvasRenderingContext2D) {
      ctx.beginPath();
      ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(16, 185, 129, ${this.alpha})`;
      ctx.fill();
    }
  }

  const initCanvas = () => {
    const canvas = document.getElementById("particles") as HTMLCanvasElement;
    if (!canvas) return;
    const ctx = canvas.getContext("2d");
    if (!ctx) return;

    let particles: Particle[] = [];
    let animationId: number;

    const resize = () => {
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
      const numParticles = window.innerWidth < 768 ? 50 : 120;
      particles = Array.from({ length: numParticles }, () => new Particle(canvas.width, canvas.height));
    };

    const animate = () => {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      particles.forEach((p) => {
        p.update(canvas.width, canvas.height);
        p.draw(ctx);
      });
      animationId = requestAnimationFrame(animate);
    };

    window.addEventListener("resize", resize);
    resize();
    animate();

    document.addEventListener('astro:before-preparation', () => {
      cancelAnimationFrame(animationId);
      window.removeEventListener("resize", resize);
    }, { once: true });
  };

  initCanvas();
  document.addEventListener('astro:after-swap', initCanvas);
</script>