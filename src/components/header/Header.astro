<section class="hero">
    <canvas class="particles-canvas" id="particles"></canvas>
    <div class="bg-layer aurora-1"></div>
    <div class="bg-layer aurora-2"></div>
    <div class="bg-layer aurora-3"></div>
    <div class="dot-grid"></div>

    <div class="container hero-container">
        <div class="badge">
            <span class="dot"></span>
            <p>Impulsando la Transformación Digital</p>
        </div>

        <h1>
            <span class="scan-line"></span>
            Construimos el <span class="highlight">Futuro Digital</span> de tu proyecto
        </h1>

        <p class="hero-description">
            En <strong class="brand">Ryzeck</strong>, transformamos ideas audaces en aplicaciones web y móviles
            de alto impacto. Especialistas en SaaS y desarrollo a medida para
            empresas que no se detienen.
        </p>

        <button class="btn-primary">
            HABLEMOS DE TU IDEA <span>→</span>
        </button>
    </div>
</section>

<style>
    .hero {
        position: relative;
        background-color: #000;
        overflow: hidden;
        padding: 95px 0;
        min-height: 80vh;
        display: flex;
        align-items: center;
        border-bottom: 1px solid #1a1a1a;
    }

    .particles-canvas {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 1;
    }

    .bg-layer {
        position: absolute;
        border-radius: 50%;
        pointer-events: none;
        filter: blur(80px);
        will-change: transform, opacity;
    }

    .aurora-1 {
        width: 700px;
        height: 700px;
        top: 50%;
        left: 50%;
        --px: 0px; --py: 0px;
        transform: translate(calc(-50% + var(--px)), calc(-50% + var(--py)));
        background: radial-gradient(circle, rgba(16, 185, 129, 0.22) 0%, transparent 70%);
        animation: aurora1float 6s ease-in-out infinite;
        z-index: 2;
    }

    .aurora-2 {
        width: 500px;
        height: 300px;
        top: 20%;
        left: 15%;
        --px: 0px; --py: 0px;
        transform: translate(var(--px), var(--py));
        background: radial-gradient(circle, rgba(16, 185, 129, 0.1) 0%, transparent 70%);
        animation: aurora2float 8s ease-in-out infinite 1s;
        z-index: 2;
    }

    .aurora-3 {
        width: 400px;
        height: 400px;
        bottom: 10%;
        right: 10%;
        --px: 0px; --py: 0px;
        transform: translate(var(--px), var(--py));
        background: radial-gradient(circle, rgba(5, 150, 105, 0.12) 0%, transparent 70%);
        animation: aurora3float 10s ease-in-out infinite 2s;
        z-index: 2;
    }

    .scan-line {
        position: absolute;
        left: -5%;
        width: 110%;
        height: 2px;
        top: 0;
        background: linear-gradient(
            90deg,
            transparent 0%,
            rgba(16, 185, 129, 0.15) 10%,
            rgba(16, 185, 129, 0.7) 50%,
            rgba(16, 185, 129, 0.15) 90%,
            transparent 100%
        );
        box-shadow: 0 0 12px rgba(16, 185, 129, 0.5), 0 0 4px rgba(16, 185, 129, 0.8);
        animation: scanThroughText 4s linear infinite;
        pointer-events: none;
        z-index: 20;
    }

    @keyframes scanThroughText {
        0%   { top: -4px;  opacity: 0;   }
        5%   {             opacity: 1;   }
        95%  {             opacity: 0.8; }
        100% { top: 110%;  opacity: 0;   }
    }

    .dot-grid {
        position: absolute;
        inset: 0;
        background-image: radial-gradient(
            circle,
            rgba(255, 255, 255, 0.07) 1px,
            transparent 1px
        );
        background-size: 32px 32px;
        mask-image: radial-gradient(
            ellipse 80% 80% at 50% 50%,
            black 30%,
            transparent 100%
        );
        -webkit-mask-image: radial-gradient(
            ellipse 80% 80% at 50% 50%,
            black 30%,
            transparent 100%
        );
        z-index: 2;
        animation: gridPulse 4s ease-in-out infinite;
        pointer-events: none;
    }

    @keyframes aurora1float {
        0%, 100% { opacity: 0.8; }
        33%       { opacity: 1;   }
        66%       { opacity: 0.6; }
    }

    @keyframes aurora2float {
        0%, 100% { opacity: 0.6; }
        50%       { opacity: 1;   }
    }

    @keyframes aurora3float {
        0%, 100% { opacity: 0.5; }
        50%       { opacity: 0.9; }
    }

    @keyframes gridPulse {
        0%, 100% { opacity: 0.6; }
        50%       { opacity: 1;   }
    }

    .hero-container {
        position: relative;
        z-index: 10;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2rem;
    }

    h1 {
        position: relative;
        font-size: clamp(2.5rem, 6vw, 4rem);
        line-height: 1.1;
        max-width: 970px;
        color: white;
        text-align: center;
        margin: 0;
        letter-spacing: -0.02em;
        font-weight: 800;
        opacity: 0;
        transform: translateY(20px);
        animation: heroFadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.2s forwards;
        overflow: visible;
    }

    .highlight {
        background: linear-gradient(
            135deg,
            #10b981 0%,
            #34d399 50%,
            #6ee7b7 100%
        );
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        background-size: 200% 200%;
        animation: shimmer 3s ease-in-out infinite;
    }

    @keyframes shimmer {
        0%, 100% { background-position: 0% 50%;   }
        50%       { background-position: 100% 50%; }
    }

    .hero-description {
        margin: 0;
        max-width: 750px;
        color: #9ca3af;
        font-size: 1.1rem;
        line-height: 1.6;
        text-align: center;
        opacity: 0;
        transform: translateY(20px);
        animation: heroFadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.4s forwards;
    }

    .brand {
        color: #10b981;
        font-weight: 800;
        font-style: normal;
    }

    .badge {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid #222;
        padding: 0.4rem 1.2rem;
        border-radius: 9999px;
        opacity: 0;
        transform: translateY(10px);
        animation: heroFadeIn 0.8s ease-out forwards;
    }

    .badge p {
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.05em;
        color: #10b981;
        text-transform: uppercase;
        margin: 0;
    }

    .dot {
        width: 6px;
        height: 6px;
        background-color: #10b981;
        border-radius: 50%;
        box-shadow: 0 0 10px rgba(16, 185, 129, 0.5);
        animation: dotPulse 2s ease-in-out infinite;
    }

    @keyframes dotPulse {
        0%, 100% { box-shadow: 0 0 6px rgba(16, 185, 129, 0.5);  }
        50%       { box-shadow: 0 0 18px rgba(16, 185, 129, 0.9); }
    }

    .btn-primary {
        position: relative;
        display: inline-flex;
        align-items: center;
        gap: 12px;
        background-color: white;
        color: black;
        padding: 1.2rem 2.5rem;
        border-radius: 8px;
        border: none;
        cursor: pointer;
        font-weight: 800;
        font-size: 0.9rem;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        overflow: hidden;
        transition:
            transform 0.2s ease,
            background-color 0.2s ease,
            box-shadow 0.2s ease;
        opacity: 0;
        animation: heroFadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.6s forwards;
    }

    .btn-primary::before {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(
            90deg,
            transparent 0%,
            rgba(16, 185, 129, 0.2) 50%,
            transparent 100%
        );
        transform: translateX(-100%);
        transition: transform 0.5s ease;
    }

    .btn-primary:hover::before {
        transform: translateX(100%);
    }

    .btn-primary:hover {
        background-color: #f0f0f0;
        transform: scale(1.03);
        box-shadow: 0 0 30px rgba(16, 185, 129, 0.25);
    }

    @keyframes heroFadeIn {
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @media (max-width: 768px) {
        .hero {
            padding: 80px 0;
            min-height: 70vh;
        }
        h1 {
            font-size: 2.2rem;
        }
        .hero-description {
            font-size: 1rem;
        }
        .aurora-1 {
            width: 400px;
            height: 400px;
        }
        .aurora-2,
        .aurora-3 {
            display: none;
        }
    }
</style>

<script>
    const canvas = document.getElementById("particles") as HTMLCanvasElement;
    const ctx = canvas.getContext("2d")!;
    let particles: Particle[] = [];
    let W: number, H: number;

    const isMobile = window.innerWidth < 768;

    function resize() {
        W = canvas.width = canvas.offsetWidth;
        H = canvas.height = canvas.offsetHeight;
    }

    class Particle {
        x!: number;
        y!: number;
        r!: number;
        vx!: number;
        vy!: number;
        alpha!: number;
        maxAlpha!: number;
        life!: number;
        maxLife!: number;

        constructor() {
            this.reset(true);
        }

        reset(init = false) {
            this.x = Math.random() * W;
            this.y = init ? Math.random() * H : H + 10;
            this.r = Math.random() * 1.5 + 0.3;
            this.vx = (Math.random() - 0.5) * 0.3;
            this.vy = -(Math.random() * 0.5 + 0.2);
            this.alpha = 0;
            this.maxAlpha = Math.random() * 0.5 + 0.1;
            this.life = 0;
            this.maxLife = Math.random() * 300 + 200;
        }

        update() {
            this.x += this.vx;
            this.y += this.vy;
            this.life++;
            const p = this.life / this.maxLife;
            if (p < 0.15) this.alpha = (p / 0.15) * this.maxAlpha;
            else if (p > 0.75) this.alpha = ((1 - p) / 0.25) * this.maxAlpha;
            else this.alpha = this.maxAlpha;
            if (this.life >= this.maxLife) this.reset();
        }

        draw() {
            ctx.save();
            ctx.globalAlpha = this.alpha;
            ctx.fillStyle = "#10b981";
            if (!isMobile) {
                ctx.shadowBlur = 8;
                ctx.shadowColor = "#10b981";
            }
            ctx.beginPath();
            ctx.arc(this.x, this.y, this.r, 0, Math.PI * 2);
            ctx.fill();
            ctx.restore();
        }
    }

    function init() {
        resize();
        particles = Array.from(
            { length: isMobile ? 40 : 80 },
            () => new Particle(),
        );
    }

    function loop() {
        ctx.clearRect(0, 0, W, H);
        particles.forEach((p) => {
            p.update();
            p.draw();
        });
        requestAnimationFrame(loop);
    }

    window.addEventListener("resize", resize);
    init();
    loop();

    // ── Parallax ──
    const a1 = document.querySelector('.aurora-1') as HTMLElement;
    const a2 = document.querySelector('.aurora-2') as HTMLElement;
    const a3 = document.querySelector('.aurora-3') as HTMLElement;

    const layers = [
        { el: a1, strength: -28 },
        { el: a2, strength: -18 },
        { el: a3, strength: -12 },
    ];

    let targetX = 0, targetY = 0;
    const current = layers.map(() => ({ x: 0, y: 0 }));

    const hero = document.querySelector('.hero') as HTMLElement;

    hero.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = hero.getBoundingClientRect();
        targetX = ((e.clientX - rect.left) / rect.width  - 0.5) * 2;
        targetY = ((e.clientY - rect.top)  / rect.height - 0.5) * 2;
    });

    hero.addEventListener('mouseleave', () => {
        targetX = 0;
        targetY = 0;
    });

    function lerp(a: number, b: number, t: number) { return a + (b - a) * t; }

    function parallaxLoop() {
        layers.forEach((layer, i) => {
            current[i].x = lerp(current[i].x, targetX * layer.strength, 0.06);
            current[i].y = lerp(current[i].y, targetY * layer.strength, 0.06);
            layer.el.style.setProperty('--px', `${current[i].x}px`);
            layer.el.style.setProperty('--py', `${current[i].y}px`);
        });
        requestAnimationFrame(parallaxLoop);
    }

    parallaxLoop();
</script>