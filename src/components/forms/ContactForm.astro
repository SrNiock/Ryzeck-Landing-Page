<form class="contact-form-component" name="contacto-ryzeck" method="POST" data-netlify="true">

    <input type="hidden" name="form-name" value="contacto-ryzeck" />

    <div class="form-group-row">
        <div class="form-group">
            <label for="name">NOMBRE</label>
            <input
                type="text"
                id="name"
                name="name"
                placeholder="Juan Pérez"
                required
            />
        </div>
        <div class="form-group">
            <label for="email">EMAIL</label>
            <input
                type="email"
                id="email"
                name="email"
                placeholder="juan@startup.com"
                required
            />
        </div>
    </div>

    <div class="form-group">
        <label>TIPO DE PROYECTO</label>
        <div class="custom-select">
            <div class="select-trigger">
                <span class="select-text">Desarrollo Web (Fullstack)</span>
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"><path d="m6 9 6 6 6-6"></path></svg
                >
            </div>
            <div class="select-options">
                <div class="option selected" data-value="web">
                    Desarrollo Web (Fullstack)
                </div>
                <div class="option" data-value="multiplataforma">
                    Desarrollo multiplataforma (iOS & Android)
                </div>
                <div class="option" data-value="android">
                    Desarrollo Android Nativo
                </div>
                <div class="option" data-value="api">
                    Diseño y Desarrollo de APIs
                </div>
            </div>
            <input
                type="hidden"
                name="type"
                class="real-type-input"
                value="web"
            />
        </div>
    </div>

    <div class="form-group">
        <label for="message">MENSAJE</label>
        <textarea
            id="message"
            name="message"
            rows="4"
            placeholder="Háblanos de tu idea..."></textarea>
    </div>

    <button type="submit" class="submit-btn">ENVIAR SOLICITUD</button>
</form>

<style>
    .contact-form-component {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }
    .form-group-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
    }

    @media (max-width: 600px) {
        .form-group-row {
            grid-template-columns: 1fr;
        }
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }
    .form-group label {
        font-size: 0.7rem;
        font-weight: 700;
        color: #555;
        letter-spacing: 0.05em;
    }
    .form-group input,
    .form-group textarea {
        background: #111;
        border: 1px solid #222;
        padding: 0.8rem;
        border-radius: 8px;
        color: white;
        font-family: inherit;
        transition: border-color 0.2s;
        resize: none;
    }
    .form-group input:focus,
    .form-group textarea:focus {
        outline: none;
        border-color: #444;
    }

    .submit-btn {
        background: white;
        color: black;
        border: none;
        padding: 1rem;
        border-radius: 8px;
        font-weight: 700;
        cursor: pointer;
        margin-top: 1rem;
        transition:
            transform 0.15s,
            background-color 0.1s;
    }
    .submit-btn:hover {
        background: #e0e0e0;
        transform: translateY(-1px);
    }

    .custom-select {
        position: relative;
        width: 100%;
        user-select: none;
    }
    .select-trigger {
        background: #111;
        border: 1px solid #222;
        padding: 0.9rem;
        border-radius: 6px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        cursor: pointer;
        color: white;
        font-size: 0.9rem;
    }
    .select-options {
        position: absolute;
        top: calc(100% + 5px);
        left: 0;
        width: 100%;
        background: #0d0d0d;
        border: 1px solid #222;
        border-radius: 6px;
        z-index: 100;
        opacity: 0;
        visibility: hidden;
        transform: translateY(-10px);
        transition: all 0.2s ease;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.5);
        overflow: hidden;
    }
    .custom-select.active .select-options {
        opacity: 1;
        visibility: visible;
        transform: translateY(0);
    }
    .custom-select.active .select-trigger svg {
        transform: rotate(180deg);
    }
    .option {
        padding: 0.9rem;
        color: #888;
        cursor: pointer;
        font-size: 0.9rem;
        transition: all 0.2s;
    }
    .option:hover {
        background: #1a1a1a;
        color: white;
    }
    .option.selected {
        color: white;
        background: #151515;
    }
</style>

<script>
    const setupForm = () => {
        const forms = document.querySelectorAll(".contact-form-component");

        forms.forEach((form) => {
            const customSelect = form.querySelector(".custom-select");
            const trigger = form.querySelector(".select-trigger");
            const options = form.querySelectorAll(".option");
            const text = form.querySelector(".select-text");
            const hiddenInput = form.querySelector(
                ".real-type-input",
            ) as HTMLInputElement;

            trigger?.addEventListener("click", (e) => {
                e.stopPropagation();
                customSelect?.classList.toggle("active");
            });

            options.forEach((opt) => {
                opt.addEventListener("click", () => {
                    const value = opt.getAttribute("data-value");
                    if (value && text && hiddenInput) {
                        text.textContent = opt.textContent;
                        hiddenInput.value = value;
                        options.forEach((o) => o.classList.remove("selected"));
                        opt.classList.add("selected");
                        customSelect?.classList.remove("active");
                    }
                });
            });
        });

        document.addEventListener("click", () => {
            document
                .querySelectorAll(".custom-select")
                .forEach((s) => s.classList.remove("active"));
        });
    };

    setupForm();
    document.addEventListener("astro:after-swap", setupForm);
</script>
